{
  "$schema": "https://cdn.statically.io/gh/nguyenngoclongdev/cdn/main/schema/v11/terminal-keeper.json",
  "theme": "default",
  "active": "default",
  "activateOnStartup": true,
  "keepExistingTerminals": false,
  "sessions": {
    "default": [
      {
        "name": "Frontend",
        "autoExecuteCommands": true,
        "commands": [
          "cd frontend\npnpm dev"
        ]
      },
      {
        "name": "Frontend - pnpm",
        "autoExecuteCommands": true,
        "commands": [
          "cd frontend\n"
        ]
      },
      {
        "name": "Backend",
        "autoExecuteCommands": true,
        "commands": [
          "cd backend\nsource ./.venv/Scripts/activate\nuvicorn main:app --reload"
        ]
      },
      {
        "name": "Backend - pip",
        "autoExecuteCommands": true,
        "commands": [
          "cd backend\nsource ./.venv/Scripts/activate"
        ]
      },
      {
        "name": "git",
        "autoExecuteCommands": false,
        "commands": [
          ""
        ]
      }
    ]
  }
}